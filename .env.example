# ===========================================
# Email Configuration (Production-Ready)
# ===========================================

# Email Backend Options: 'django.core.mail.backends.smtp.EmailBackend' or 'anymail.backends.console.EmailBackend' for testing
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP Configuration (Gmail SMTP example - for App Password, see: https://support.google.com/accounts/answer/185833)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# IMPORTANT: Use App Password for Gmail (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Default sender name
DEFAULT_FROM_EMAIL=ExpenseWise <your-email@gmail.com>

# Optional: SendGrid configuration
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# ===========================================
# Celery Configuration (for async emails)
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_TASK_TRACK_STARTED=True

# ===========================================
# Email Rate Limiting
# ===========================================
# Minimum seconds between emails of same type (anti-spam)
EMAIL_RATE_LIMIT_SECONDS=300  # 5 minutes
